#!/usr/bin/env zsh
#
# minimal theme — clean 16-colour ANSI palette
#

source "${SHUI_DIR}/src/themes/default.zsh"

SHUI_COLOR_PRIMARY=$'\033[0;33m'
SHUI_COLOR_SUCCESS=$'\033[0;32m'
SHUI_COLOR_WARNING=$'\033[0;33m'
SHUI_COLOR_ERROR=$'\033[0;31m'
SHUI_COLOR_INFO=$'\033[0;34m'
SHUI_COLOR_MUTED=$'\033[0;90m'
SHUI_COLOR_ACCENT=$'\033[1;33m'
SHUI_COLOR_SECONDARY=$'\033[0;37m'
SHUI_COLOR_DANGER=$'\033[0;31m'

SHUI_COLOR_CYAN=$'\033[0;36m'
SHUI_COLOR_WHITE=$'\033[0;37m'
SHUI_COLOR_MAGENTA=$'\033[0;35m'
SHUI_COLOR_BOLD_WHITE=$'\033[1;37m'

SHUI_BG_SUCCESS=$'\033[42m'
SHUI_BG_WARNING=$'\033[43m'
SHUI_BG_ERROR=$'\033[41m'
SHUI_BG_INFO=$'\033[44m'
SHUI_BG_PRIMARY=$'\033[43m'
SHUI_BG_MUTED=$'\033[100m'
